{
  "name": "profit-web",
  "version": "0.3.4",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3000": "next dev -p 3000",
    "dev:3001": "next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:repair": "prisma db execute --file prisma/repair-compass-alert-rule.sql --schema prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:seed:reference": "tsx prisma/seed-reference.ts",
    "db:backup": "tsx prisma/backup-sqlite.ts",
    "db:studio": "prisma studio",
    "auth:create-user": "tsx prisma/create-user.ts",
    "content:sync-strategy": "cp ../docs/VALUE_STRATEGY_DEPLOYMENT_ROADMAP.md ./content/VALUE_STRATEGY_DEPLOYMENT_ROADMAP.md"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.11",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}

    "prestart": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "release:preflight": "bash scripts/release-preflight.sh",
    "zt:acceptance": "bash scripts/zt-acceptance.sh",
    "smoke:profit": "bash scripts/smoke-profit.sh",
    "smoke:zt": "bash scripts/smoke-zt.sh",
    "gate:sha": "bash scripts/verify-sha-gate.sh",

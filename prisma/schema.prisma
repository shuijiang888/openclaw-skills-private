generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  tier      String    @default("NORMAL")
  arDays    Int       @default(30)
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id           String   @id @default(cuid())
  name         String
  productName  String   @default("")
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quantity     Int      @default(1)
  leadDays     Int      @default(15)
  isStandard   Boolean  @default(true)
  isSmallOrder Boolean  @default(true)
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quote        Quote?
}

model Quote {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  material       Float
  labor          Float
  overhead       Float
  period         Float
  coeffCustomer  Float    @default(1.15)
  coeffIndustry  Float    @default(1.1)
  coeffRegion    Float    @default(0.95)
  coeffProduct   Float    @default(1.2)
  coeffLead      Float    @default(1.08)
  coeffQty       Float    @default(0.92)
  suggestedPrice Float
  counterPrice   Float?
  approvedPrice  Float?
  pendingRole    String?
  wsPrice        Float    @default(85)
  wsRelation     Float    @default(90)
  wsDelivery     Float    @default(88)
  wsTech         Float    @default(92)
  wsPayment      Float    @default(75)
  aiSuggestion   String   @default("")
  benchmarksJson String   @default("[]")
  timelineJson   String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CompassItem {
  id           String @id @default(cuid())
  name         String
  customerName String
  grossMargin  Float
  growth       Float
  quadrant     String
  strategy     String
  priority     String
  sortOrder    Int    @default(0)
}

/// 罗盘四象限划分阈值（单例 id=default）：高毛利 / 高增长的百分数阈值
model CompassQuadrantThreshold {
  id             String   @id
  marginHighPct  Float
  growthHighPct  Float
  updatedAt      DateTime @updatedAt
}

/// 罗盘「对策矩阵」阈值规则（种子初始化，一期后台只读展示；生产可接配置页）
model CompassAlertRule {
  id              String @id @default(cuid())
  conditionLabel  String
  actionLabel     String
  sortOrder       Int    @default(0)
}

/// A2：助手/审批等关键操作的轻量审计（演示；生产可迁日志管道）
model AgentAuditLog {
  id         String   @id @default(cuid())
  requestId  String
  route      String
  action     String
  actorRole  String   @default("")
  metaJson   String   @default("{}")
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// 会话登录（PROFIT_AUTH_MODE=session）；仅新增表，db push 不破坏既有业务数据
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @default("")
  passwordHash String
  /// 业务角色：SALES_MANAGER | SALES_DIRECTOR | SALES_VP | GM | ADMIN
  role         String   @default("SALES_DIRECTOR")
  mobile       String   @default("")
  isActive     Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)
  /// 智探007 组织归属（可为空）
  orgUnitId    String?
  orgUnit      ZtOrgUnit? @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)
  /// 用户侧交互调用大模型权限（仍受系统总开关约束）
  ztAllowInteractiveLlm Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ztPointWallet          ZtPointWallet?
  ztPointLedgers         ZtPointLedger[]
  ztSubmissions          ZtSubmission[]
  ztRedemptions          ZtRedemption[]
  ztRankChanges          ZtRankChangeLog[]
  ztSystemConfigsUpdated ZtSystemConfig[] @relation("ZtConfigUpdatedBy")
}

/// 智探007 组织单元（可扩展为多租户/多层级组织）
model ZtOrgUnit {
  id        String      @id @default(cuid())
  name      String
  code      String      @unique
  parentId  String?
  parent    ZtOrgUnit?  @relation("ZtOrgUnitTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ZtOrgUnit[] @relation("ZtOrgUnitTree")
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users User[]

  @@index([sortOrder, createdAt])
}

/// 智探007：多模态信号（MVP 结构化）
model ZtSignal {
  id           String   @id @default(cuid())
  title        String
  content      String
  signalType   String   @default("tactical")
  region       String   @default("")
  sourceFormat String   @default("text")
  actorRole    String   @default("SALES_DIRECTOR")
  status       String   @default("NEW")
  points       Int      @default(8)
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

/// 智探007：今日行动卡
model ZtActionCard {
  id           String   @id @default(cuid())
  title        String
  reason       String
  suggestion   String
  priority     String   @default("P1")
  status       String   @default("OPEN")
  assignedRole String   @default("SALES_DIRECTOR")
  rewardPoints Int      @default(10)
  dueAt        DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([assignedRole, status])
}

/// 智探007：任务悬赏
model ZtBountyTask {
  id           String   @id @default(cuid())
  title        String
  description  String
  taskType     String   @default("tactical")
  rewardPoints Int      @default(30)
  status       String   @default("OPEN")
  deadlineAt   DateTime?
  createdAt    DateTime @default(now())

  submissions  ZtSubmission[]

  @@index([status, createdAt])
}

/// 智探007：任务/自由情报提交
model ZtSubmission {
  id           String       @id @default(cuid())
  taskId       String?
  task         ZtBountyTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  title        String
  content      String
  signalType   String       @default("tactical")
  region       String       @default("")
  format       String       @default("text")
  userId       String?
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorName    String       @default("")
  actorRole    String       @default("SALES_DIRECTOR")
  status       String       @default("PENDING")
  pointsGranted Int         @default(0)
  createdAt    DateTime     @default(now())

  @@index([actorRole, createdAt])
  @@index([userId, createdAt])
}

/// 智探007：角色积分钱包（MVP 按角色汇总）
model ZtPointWallet {
  id                String   @id @default(cuid())
  actorRole         String?  @unique
  userId            String?  @unique
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  points            Int      @default(0)
  lifetimePoints    Int      @default(0)
  rank              String   @default("战士")
  rankLevel         Int      @default(1)
  lastRankChangedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([points, updatedAt])
}

/// 智探007：积分流水
model ZtPointLedger {
  id           String   @id @default(cuid())
  actorRole    String
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorName    String   @default("")
  action       String
  points       Int
  balanceAfter Int      @default(0)
  rankAfter    String   @default("战士")
  refType      String   @default("")
  refId        String   @default("")
  createdAt    DateTime @default(now())

  @@index([actorRole, createdAt])
  @@index([userId, createdAt])
}

/// 智探007：积分兑换申请（线下核销）
model ZtRedemption {
  id            String   @id @default(cuid())
  actorRole     String
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorName     String   @default("")
  rankAtRequest String   @default("战士")
  item          String
  pointsCost    Int
  redeemCode    String   @unique
  status        String   @default("REQUESTED")
  createdAt     DateTime @default(now())
  verifiedAt    DateTime?

  @@index([actorRole, createdAt])
  @@index([userId, createdAt])
}

/// 智探007：军衔变更记录（自动升降级留痕）
model ZtRankChangeLog {
  id        String   @id @default(cuid())
  actorRole String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  oldRank   String
  newRank   String
  points    Int
  reason    String   @default("")
  createdAt DateTime @default(now())

  @@index([actorRole, createdAt])
  @@index([userId, createdAt])
}

/// 智探007：系统维护配置（单例 id=default）
model ZtSystemConfig {
  id                          String   @id
  llmEnabled                  Boolean  @default(true)
  llmProvider                 String   @default("minimax")
  llmModel                    String   @default("MiniMax-M2.7")
  llmInteractiveEnabled       Boolean  @default(true)
  llmPasswordRequired         Boolean  @default(true)
  llmAutomationBypassPassword Boolean  @default(true)
  mobileExperienceEnabled     Boolean  @default(true)
  multiEndpointEnabled        Boolean  @default(true)
  featuresJson                String   @default("{}")
  updatedByUserId             String?
  updatedByUser               User?    @relation("ZtConfigUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  updatedAt                   DateTime @updatedAt
}

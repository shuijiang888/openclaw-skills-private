# 复制为 .env 后按需修改
DATABASE_URL="file:./prisma/dev.db"

# 自用真实数据验证：单独一个库文件，切勿对该库执行 npm run db:seed（会整库清空）
# DATABASE_URL="file:./prisma/real.db"
# 仅补罗盘默认阈值/对策规则（不删客户与项目）：npm run db:seed:reference
# 备份当前 SQLite 文件：npm run db:backup → prisma/backups/

# —— 正式登录（与演示切换互斥）——
# 设为 session 并配置密钥后：须登录访问工作台/项目/罗盘/控制台；API 仅信任 Cookie 会话，忽略 x-demo-role。
# 构建前端须知：NEXT_PUBLIC_PROFIT_AUTH_MODE 须与 PROFIT_AUTH_MODE 保持一致（供导航等客户端判断）。
# PROFIT_AUTH_MODE=session
# NEXT_PUBLIC_PROFIT_AUTH_MODE=session
# 随机字符串，至少 16 字符（示例勿照抄）
# PROFIT_AUTH_SECRET=change-me-to-a-long-random-string
# 建账号：npx prisma generate && npx prisma db push && npm run auth:create-user -- user@corp.com '密码' ADMIN

# 登录限流（单实例；多副本请加网关）：默认 20 次 / 15 分钟 / IP，设 PROFIT_LOGIN_RL_MAX=0 关闭
# PROFIT_LOGIN_RL_MAX=20
# PROFIT_LOGIN_RL_WINDOW_MS=900000

# 报价智能助手：启用本机 Ollama（与 README「本机大模型」一节一致）
# OLLAMA_ENABLED=1
# OLLAMA_MODEL=qwen3.5:35b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# 35B 在 CPU 上可能极慢，默认 300000（5 分钟）
# OLLAMA_TIMEOUT_MS=300000
# Ollama JSON 模式（推荐开启；若兼容问题可设 OLLAMA_JSON_FORMAT=0）
# OLLAMA_JSON_FORMAT=1
# OLLAMA_NUM_PREDICT=2048
# OLLAMA_TEMPERATURE=0.15

# —— SSRF 防护：仅允许本机 / 内网 IPv4 主机，除非显式放行 ——
# Docker 服务名等非 IP 主机请加入允许列表（逗号分隔）
# OLLAMA_HOST_ALLOWLIST=ollama,host.docker.internal
# 公网或任意主机上的 Ollama（需自担风险）
# OLLAMA_ALLOW_REMOTE_HOST=1

# —— MiniMax 在线大模型（可选，与 Ollama 二选一或并存；默认优先 MiniMax）——
# MINIMAX_ENABLED=1
# MINIMAX_API_KEY=sk-xxxx
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_TIMEOUT_MS=90000
# MINIMAX_TEMPERATURE=0.2

# —— 大模型口令闸门（每次调用都要输入，便于公网成本控制）——
# 生产默认开启（可用 PROFIT_LLM_PASSWORD_REQUIRED 显式控制）
# PROFIT_LLM_PASSWORD_REQUIRED=1
# 二选一配置口令：推荐使用 SHA256 哈希（避免明文）
# PROFIT_LLM_ACCESS_PASSWORD=your-plain-password
# PROFIT_LLM_ACCESS_PASSWORD_SHA256=your_password_sha256_hex

# —— Agent API 生产加固 ——
# POST /api/assistant/quote-parse 每秒并发建议前置网关再限；以下为进程内粗略限制（单实例）
# PROFIT_AGENT_RL_MAX=40
# PROFIT_AGENT_RL_WINDOW_MS=60000
# 设为 0 关闭限流（仅建议在可信内网）
# PROFIT_AGENT_RL_MAX=0

# 单次解析允许的最大字符数
# PROFIT_AGENT_MAX_TEXT_CHARS=16000

# CSRF：生产环境默认开启；本地开发若需关闭可设 0
# PROFIT_AGENT_CSRF=0
# 公网 HTTP（未上 HTTPS）部署可关闭 secure-cookie 要求，避免浏览器不回传 CSRF Cookie
# PROFIT_AGENT_CSRF_COOKIE_SECURE=0

# Ollama 探测接口是否隐藏 baseUrl 与模型列表（生产默认隐藏，开发可调为 0 查看）
# PROFIT_REDACT_AGENT_PROBE=1

# 报价助手系统提示词版本见代码 lib/prompts/quote-parse-system.ts（QUOTE_PARSE_PROMPT_VERSION）
# 审计日志含 textSha256Prefix / injectionSignals / promptVersion，不落库用户原文

# —— 平台封面密码门禁（独立于登录会话）——
# 6位数字密码（示例），生产请替换
# AUTH_PASSWORD=888888
# 封面门禁会话签名密钥（至少16位随机串）
# AUTH_GATE_SECRET=change-me-to-a-long-random-string
# HTTP 场景建议 0；HTTPS 场景建议 1（控制 ai_platform_auth 的 secure 标记）
# AUTH_GATE_COOKIE_SECURE=0

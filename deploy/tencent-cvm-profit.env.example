# 复制为 tencent-cvm-profit.env 后填写，再 source 运行 deploy/tencent-cvm-profit-docker.sh

# 至少 16 位随机串（勿泄露）
PROFIT_AUTH_SECRET=请改为随机长字符串至少十六位

# SQLite：与挂载卷一致（容器内 /app/prisma 对应宿主机项目目录下 prisma/）
DATABASE_URL="file:./prisma/prod.db"

# 门户「智能情报系统」卡片跳转地址（须与 Nginx 实际对外路径一致）
NEXT_PUBLIC_PORTAL_APP_INTELLIGENCE_URL=http://119.45.205.137/

# 构建/运行需一致
NEXT_PUBLIC_PROFIT_AUTH_MODE=session

# 访问 / 时重定向到 /portal（推荐生产开启）
PROFIT_ROOT_REDIRECT=portal

# 宿主机映射端口（Nginx 反代到该端口）
HOST_PORT=3000
